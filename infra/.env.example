# --- LLM (local Ollama) ---
# Ollama runs on the host (native install). Backend container reaches it via host.docker.internal.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_MODEL_FAST=qwen2.5:7b-instruct
OLLAMA_EMBED_MODEL=mxbai-embed-large

# --- Travel APIs ---
DUFFEL_API_KEY=
LITEAPI_API_KEY=
GOOGLE_PLACES_API_KEY=
OPENWEATHER_API_KEY=

# --- Google OAuth (Gmail + Calendar) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost/api/auth/google/callback

# --- Infra ---
POSTGRES_USER=travel
POSTGRES_PASSWORD=travel
POSTGRES_DB=travel
POSTGRES_URL=postgresql+asyncpg://travel:travel@postgres:5432/travel
REDIS_URL=redis://redis:6379/0

# --- App ---
SESSION_SECRET=
APP_BASE_URL=http://localhost
FRONTEND_BASE_URL=http://localhost
